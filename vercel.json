{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "env": {
    "FLASK_ENV": "production",
    "PYTHONUNBUFFERED": "1",
    "VERCEL": "1"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
