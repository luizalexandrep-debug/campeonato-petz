# Campeonato Petz 2026 - Configurações de Ambiente

# Modo Flask (development ou production)
FLASK_ENV=development

# Chave Secreta (mude isso em produção!)
# Gere uma chave segura com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-aleatoria

# Cookies seguros (True em produção com HTTPS)
SESSION_COOKIE_SECURE=False

# Banco de dados
DATABASE_URL=sqlite:///campeonato.db

# Porta do servidor
FLASK_PORT=5000

# Host
FLASK_HOST=0.0.0.0
